<view class="page">
  <view class="header">
    <text class="title">最近 {{count}} 张</text>
    <text class="sub">更新时间：{{updatedAt || "-"}}</text>
  </view>

  <view class="grid">
    <block wx:for="{{items}}" wx:key="id">
      <view class="card" bindtap="onPreview" data-index="{{index}}">
        <image
          class="img"
          mode="aspectFill"
          src="{{item.url}}"
          lazy-load="true"
        />
        <view class="meta">
          <text class="date">{{item.date}}</text>
        </view>
      </view>
    </block>
  </view>

  <view wx:if="{{!loading && items.length === 0}}" class="empty">
    <text>暂无图片</text>
  </view>
</view>

