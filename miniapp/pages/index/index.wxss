.page {
  padding: 16rpx 16rpx 40rpx;
}

.header {
  padding: 12rpx 8rpx 20rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 600;
  color: #111827;
  display: block;
}

.sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b7280;
  display: block;
}

.grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.card {
  border-radius: 16rpx;
  overflow: hidden;
  background: #f3f4f6;
}

.img {
  width: 100%;
  height: 340rpx;
  background: #e5e7eb;
}

.meta {
  padding: 10rpx 12rpx;
}

.date {
  font-size: 22rpx;
  color: #374151;
}

.empty {
  margin-top: 48rpx;
  text-align: center;
  color: #6b7280;
  font-size: 26rpx;
}

